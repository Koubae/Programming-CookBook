    // ----------------------------------------------------------------------------
    //                          JetBrains Darcula Theme
    // ----------------------------------------------------------------------------
    // 
    // https://marketplace.visualstudio.com/items?itemName=Anan.jetbrains-darcula-theme&ssr=false#overview
    "editor.tokenColorCustomizations": {
        "[JetBrains Darcula Theme]": {
            // "textMateRules": [
            //     {
            //         "scope": [
            //             "source.python"
            //         ],
            //         "settings": {
            //             "foreground": "#e06c75"
            //         }
            //     }
            // ]
            "textMateRules": [
                {
                    "scope": [
                        // "variable",
                        "variable.other",
                        "variable.other.readwrite",
                        "variable.other.object",
                        "variable.other.member",
                        "variable.other.property",
                        "variable.other.class",
                        "variable.other.instance",
                        "support.variable.property",
                        "meta.property-name",
                        "variable.other.constant",
                        "variable.other.constant.property",
                        "variable.other.class.property",
                        "variable.other.class.attribute",
                        "meta.class-field",
                        "variable.python",
                        "variable.name",
                        "constant",
                        "entity.name.variable"
                    ],
                    "settings": {
                        "foreground": "#A9B7C6"
                    }
                },
                  {
                    "scope": [
                        "constant.language.python"
                    ],
                    "settings": {
                        "foreground": "#CC7832"
                    }
                }
            ]
        }
    },
    // ----------------------------------------------------------------------------
    //                           Material Icon Theme
    // ----------------------------------------------------------------------------
    "material-icon-theme.folders.associations": {
        ".windsurf": "robot"
    },
    // ----------------------------------------------------------------------------
    //                           File Associations
    // --------------------------aaaaaaaaaaaaa--------------------------------------------------
    // "files.associations": {
    //     "*.sql": "vscode-postgres"
    // },
    // ----------------------------------------------------------------------------
    //                            GO
    // ----------------------------------------------------------------------------
    // https://www.youtube.com/watch?v=pvfESSAbbts
    // @docs https://go.dev/gopls/features/transformation
    "[go]": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "[go.mod]": {
        "editor.formatOnSave": false,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "never"
        }
    },
    "gopls": {
        "ui.semanticTokens": false
    },
    "terminal.external.windowsExec": "C:\\Program Files\\Git\\bin\\bash.exe",
    "terminal.integrated.profiles.windows": {
        "PowerShell": {
            "source": "PowerShell",
            "icon": "terminal-powershell"
        },
        "Command Prompt": {
            "path": [
                "${env:windir}\\Sysnative\\cmd.exe",
                "${env:windir}\\System32\\cmd.exe"
            ],
            "args": [],
            "icon": "terminal-cmd"
        },
        "Git Bash": {
            "path": "C:\\Program Files\\Git\\bin\\bash.exe",
            "args": [
                "--login",
                "-i"
            ]
        }
    },
    // ----------------------------------------------------------------------------
    //                            Python
    // ----------------------------------------------------------------------------
    "ruff.enable": true,
    "ruff.lint.enable": true,
    "[python]": {
        // "editor.formatOnSave": true,
        // "editor.defaultFormatter": "ms-python.black-formatter",
        // "editor.codeActionsOnSave": {
        //     "source.organizeImports": "explicit"
        // }
    },
    // ----------------------------------------------------------------------------
    //                            Git lens
    // ----------------------------------------------------------------------------
    // Git lens
    // https://help.gitkraken.com/gitlens/gitlens-settings/#remote-provider-integration-settings
    "gitlens.integrations.enabled": true,
    "gitlens.remotes": [
        {
            "regex": "git@([^:]+):\\d+/(.+)\\.git",
            "type": "BitbucketServer"
        }
    ],
    "terminal.integrated.defaultProfile.windows": "Git Bash",
    "git.blame.editorDecoration.enabled": true,
    "windsurf.allowCascadeAccessGitignoreFiles": true,
    "makefile.configureOnOpen": false,
    "remote.autoForwardPortsSource": "hybrid",
    "terminal.integrated.showCommandHint": false,
    "material-icon-theme.folders.theme": "specific",
    "workbench.editor.limit.value": 20,
    "diffEditor.renderSideBySide": false,
    "basedpyright.analysis.typeCheckingMode": "standard",
    "claudeCode.preferredLocation": "panel"
}